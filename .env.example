# -----------------------------------------------------------------
# RAGML - LLM config  (Groq preferred, Kimi fallback)
# Copy to `.env`. Set EITHER (or both) of the keys below.
# -----------------------------------------------------------------
# Auto-priority at runtime:
#   1. GROQ_API_KEY -> Groq llama-3.3-70b   (free tier, fast - preferred)
#   2. KIMI_API_KEY -> Kimi K2              (paid fallback)

# -- Groq (preferred) --   Sign up: https://console.groq.com/
GROQ_API_KEY=gsk_xxxxx

# -- Kimi (fallback) --    Sign up: https://platform.moonshot.ai/
KIMI_API_KEY=sk-moonshot-xxxxx

# -- Optional explicit overrides (skip auto-detection) --
# LLM_API_KEY=...
# LLM_BASE_URL=...
# LLM_MODEL=...

# -- Optional: cross-family judge (e.g. Groq generates, Kimi judges) --
# JUDGE_API_KEY=sk-moonshot-xxxxx
# JUDGE_BASE_URL=https://api.moonshot.ai/v1
# JUDGE_MODEL=kimi-k2-0711-preview

# -- Rate limits --
LLM_RATE_PER_MIN=20
LLM_BUCKET_CAPACITY=10
